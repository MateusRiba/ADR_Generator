{
  "manifest_version": 3,
  "name": "ADR Generator",
  "version": "0.0.1",
  "description": "Captura transcrição do Google Meet e gera Architecture Decision Records via Gemini API.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "ADR Generator"
  },
  "options_page": "src/options/index.html",
  "permissions": ["storage"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://meet.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content/meet_capture.ts"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/service_worker.ts",
    "type": "module"
  }
}
